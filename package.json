{
  "devDependencies": {
    "@ast-grep/cli": "^0.40.4",
    "@codyswann/lisa": "^2.176.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-oxlint": "^1.62.0",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "husky": "^8.0.0",
    "jiti": "^2.4.0",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "^1.56.1",
    "prettier": "^3.3.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "uuid": "^13.0.0",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "build": "tsc && node dist/build/build.js",
    "postinstall": "[ -n \"$CI\" ] || node node_modules/@codyswann/lisa/dist/index.js --yes --skip-git-check . 2>/dev/null || true",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "seed": "bun run build && node dist/scripts/seed.js",
    "verify": "bun run build && node dist/scripts/verify.js",
    "dev:server": "bun run build && node dist/scripts/dev_server.js",
    "deploy": "bun run build && node dist/scripts/deploy.js",
    "seed:rest": "bun run build && node dist/scripts/seed_via_rest.js",
    "verify:rest": "bun run build && node dist/scripts/verify_via_rest.js",
    "baseline:data-depth": "bun run build && node dist/scripts/capture_data_depth_baseline.js",
    "verify:recruiting-market": "bun run build && node dist/scripts/verify_recruiting_market.js",
    "preview": "bun run build && node dist/scripts/preview_feed.js",
    "smoke": "bun run build && bun run smoke:run",
    "smoke:brokercheck": "bun run build && bun tests/brokercheck_web_smoke.ts",
    "token": "bun run build && node dist/scripts/get_token.js",
    "crawl:wpjson": "bun run build && node dist/scripts/crawl_via_wpjson.js",
    "crawl:html": "bun run build && node dist/scripts/crawl_html.js",
    "crawl:playwright": "bun run build && node dist/scripts/crawl_playwright.js",
    "extract:fields": "bun run build && node dist/scripts/extract_fields.js",
    "extract:helper": "bun run build && node dist/scripts/extract_helper.js",
    "ingest": "bun run build && node dist/scripts/ingest.js",
    "load:extractions": "bun run build && node dist/scripts/load_extractions.js",
    "backfill:recruiting-articles": "bun run build && node dist/scripts/backfill_recruiting_articles.js",
    "data:coverage": "bun run build && node dist/scripts/data_coverage_report.js",
    "brokercheck": "bun run build && node dist/scripts/fetch_brokercheck.js",
    "brokercheck:crawl": "bun run build && node dist/scripts/brokercheck_crawl_all.js",
    "smoke:run": "bun tests/web_smoke.ts || (echo '::warning::smoke first attempt failed; retrying once. A deterministic regression fails both runs; only true dev-cluster transients should pass on retry. Investigate if this recurs.' && bun tests/web_smoke.ts)",
    "test:e2e": "bash scripts/e2e-local-harper.sh",
    "bootstrap": "bash scripts/bootstrap.sh",
    "setup:deploy-key": "setup-deploy-key",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "start": "harperdb start",
    "stop": "harperdb stop",
    "status": "harperdb status",
    "firms:merge-aliases": "bun run build && node dist/scripts/merge_firm_aliases.js",
    "media:backfill": "bun run build && node dist/scripts/backfill_media.js",
    "scrape:rbc": "bun run build && node dist/scripts/scrape_rbc.js",
    "scrape:raymond-james": "bun run build && node dist/scripts/scrape_raymond_james.js",
    "scrape:edward-jones": "bun run build && node dist/scripts/scrape_edward_jones.js",
    "scrape:stifel": "bun run build && node dist/scripts/scrape_stifel.js",
    "scrape:ubs": "bun run build && node dist/scripts/scrape_ubs.js",
    "scrape:merrill": "bun run build && node dist/scripts/scrape_merrill.js",
    "scrape:morgan-stanley": "bun run build && node dist/scripts/scrape_morgan_stanley.js",
    "scrape:wells-fargo": "bun run build && node dist/scripts/scrape_wells_fargo.js",
    "firm-source:major-imports": "bun run build && node dist/scripts/run_major_firm_imports.js",
    "research:advisors": "bun run build && node dist/scripts/research_advisors.js",
    "backfill:search-index": "bun run build && node dist/scripts/backfill-advisor-search-index.js",
    "reindex:advisor-tokens": "bun run build && node dist/scripts/reindex-advisor-tokens.js",
    "backfill:article-dates": "bun run build && node dist/scripts/backfill_article_published_dates.js",
    "reset": "harperdb stop || true; [ -n \"$HOME\" ] && rm -rf \"$HOME/.harperdb\" && bun run bootstrap && bun run seed && bun run verify",
    "lint": "oxlint && eslint . --quiet",
    "format:check": "prettier --check .",
    "format": "prettier --check . --write",
    "test:unit": "vitest run --exclude='**/integration/**'",
    "test:setup:playwright": "bunx playwright install chromium",
    "test:watch": "vitest",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "sg:scan": "ast-grep scan",
    "prepare": "husky install || true"
  },
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "pnpm": "please-use-bun",
    "bun": ">= 1.3.11",
    "node": ">= 22.21.1"
  },
  "name": "advisory-rankings",
  "version": "0.1.543",
  "description": "Advisor data schema (sourced from AdvisorHub) running on Harper.",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:44395/git/CodySwannGT/advisory-rankings"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "domhandler": "^5.0.3",
    "harperdb": "^4.7.29"
  },
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.2",
    "esbuild": ">=0.28.1",
    "handlebars": ">=4.7.9",
    "vite": ">=8.0.16",
    "ws": ">=8.21.0",
    "undici": "^7.28.0",
    "lodash": ">=4.18.1",
    "form-data": ">=4.0.6"
  },
  "overrides": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.2",
    "esbuild": ">=0.28.1",
    "handlebars": ">=4.7.9",
    "vite": "^8.0.16",
    "ws": ">=8.21.0",
    "undici": "^7.28.0",
    "lodash": ">=4.18.1",
    "form-data": ">=4.0.6"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@codyswann/lisa",
    "@sentry/cli"
  ],
  "packageManager": "bun@1.3.11"
}
