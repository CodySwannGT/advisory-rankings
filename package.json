{
  "name": "advisory-rankings",
  "version": "0.1.0",
  "description": "Advisor data schema (sourced from AdvisorHub) running on Harper.",
  "private": true,
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "start": "harperdb start",
    "stop": "harperdb stop",
    "status": "harperdb status",
    "seed": "python3 harper-app/seed.py",
    "verify": "python3 harper-app/verify.py",
    "preview": "node scripts/preview_feed.mjs",
    "dev:server": "node scripts/dev_server.mjs",
    "deploy": "node scripts/deploy.mjs",
    "smoke": "node tests/web_smoke.mjs",
    "reset": "harperdb stop || true; rm -rf $HOME/.harperdb && npm run bootstrap && npm run seed && npm run verify"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:44395/git/CodySwannGT/advisory-rankings"
  },
  "dependencies": {
    "harperdb": "^4.7.29"
  },
  "devDependencies": {
    "playwright": "^1.56.1"
  },
  "engines": {
    "node": ">=18"
  }
}
