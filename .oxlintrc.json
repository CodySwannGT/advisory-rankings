{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/@codyswann/lisa/oxlint/harper-fabric.json",
    "./node_modules/@codyswann/lisa/oxlint/typescript.json"
  ],
  "rules": {
    "jsdoc/empty-tags": "warn",
    "jsdoc/require-yields": "warn"
  },
  "ignorePatterns": [
    "build/**",
    "dist/**",
    ".build/**",
    "coverage/**",
    "node_modules/**",
    "*.generated.*",
    "**/__generated__/**",
    "**/generated/**",
    "harper-app/resources.js",
    "harper-app/resource-*.js",
    "harper-app/web/**",
    "harper-app/lib/**",
    "harper-app/*.js"
  ]
}
